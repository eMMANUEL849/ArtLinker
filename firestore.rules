rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userDocExists(uid) {
      return exists(userPath(uid));
    }

    function myUserDocExists() {
      return isSignedIn() && userDocExists(request.auth.uid);
    }

    function myRole() {
      return get(userPath(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return myUserDocExists() && myRole() == "admin";
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasRole(roleName) {
      return myUserDocExists() && myRole() == roleName;
    }

    function isProvider() {
      return hasRole("service_provider");
    }

    function isJobParticipant() {
      return isSignedIn() &&
        (
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid
        );
    }

    function isNewJobParticipant() {
      return isSignedIn() &&
        (
          request.resource.data.clientId == request.auth.uid ||
          request.resource.data.providerId == request.auth.uid
        );
    }

    function isDmParticipantExisting() {
      return isSignedIn() &&
        (
          resource.data.senderId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid
        );
    }

    function isDmParticipantNew() {
      return isSignedIn() &&
        (
          request.resource.data.senderId == request.auth.uid ||
          request.resource.data.receiverId == request.auth.uid
        );
    }

    function isChatParticipantExisting() {
      return isSignedIn() &&
        (
          ("userIds" in resource.data && resource.data.userIds.hasAny([request.auth.uid])) ||
          ("participantIds" in resource.data && resource.data.participantIds.hasAny([request.auth.uid]))
        );
    }

    function isChatParticipantNew() {
      return isSignedIn() &&
        (
          ("userIds" in request.resource.data && request.resource.data.userIds.hasAny([request.auth.uid])) ||
          ("participantIds" in request.resource.data && request.resource.data.participantIds.hasAny([request.auth.uid]))
        );
    }

    function isPaymentReader() {
      return isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid ||
          (
            "providerIds" in resource.data &&
            resource.data.providerIds.hasAny([request.auth.uid])
          ) ||
          isAdmin()
        );
    }

    function isPaymentCreator() {
      return isSignedIn() &&
        (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.clientId == request.auth.uid ||
          isAdmin()
        );
    }

    function isReceiptReader() {
      return isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          resource.data.clientId == request.auth.uid ||
          resource.data.providerId == request.auth.uid ||
          (
            "providerIds" in resource.data &&
            resource.data.providerIds.hasAny([request.auth.uid])
          ) ||
          isAdmin()
        );
    }

    function isReceiptCreator() {
      return isSignedIn() &&
        (
          request.resource.data.userId == request.auth.uid ||
          request.resource.data.clientId == request.auth.uid ||
          isAdmin()
        );
    }

    match /settings/{document} {
      allow read, write: if isSignedIn();
    }
  match /users/{userId}/receipts/{receiptId} {
  allow read: if isSignedIn() && request.auth.uid == userId;

  allow create: if isSignedIn() &&
    request.auth.uid == userId &&
    request.resource.data.userId == request.auth.uid;

  allow update: if isSignedIn() &&
    request.auth.uid == userId &&
    resource.data.userId == request.auth.uid;

  allow delete: if isSignedIn() &&
    request.auth.uid == userId &&
    resource.data.userId == request.auth.uid;
}
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /likedPosts/{postId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /savedPosts/{postId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() &&
          (
            isOwner(userId) ||
            followerId == request.auth.uid ||
            isAdmin()
          );
        allow update: if isOwner(userId) || isAdmin();
      }
      
       


      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() &&
          (
            isOwner(userId) ||
            followingId == request.auth.uid ||
            isAdmin()
          );
        allow update: if isOwner(userId) || isAdmin();
      }

      match /collections/{collectionId} {
        allow read, create, update, delete: if isOwner(userId) || isAdmin();
      }
    }

    match /posts/{postId} {
      allow read: if true;

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow delete: if isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      match /likes/{likeId} {
        allow read: if true;

        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid;

        allow delete: if isSignedIn() &&
          resource.data.userId == request.auth.uid;

        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if true;

        allow create: if isSignedIn() &&
          request.resource.data.userId == request.auth.uid;

        allow update: if isSignedIn() &&
          (
            resource.data.userId == request.auth.uid ||
            isAdmin()
          );

        allow delete: if isSignedIn() &&
          (
            resource.data.userId == request.auth.uid ||
            isAdmin()
          );
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() &&
        (
          resource.data.recipientId == request.auth.uid ||
          resource.data.userId == request.auth.uid ||
          resource.data.senderId == request.auth.uid ||
          isAdmin()
        );

      allow create: if isSignedIn() &&
        (
          request.resource.data.senderId == request.auth.uid ||
          request.resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow update: if isSignedIn() &&
        (
          resource.data.recipientId == request.auth.uid ||
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow delete: if isAdmin();
    }

    match /receipts/{receiptId} {
  allow read: if isSignedIn() &&
    (
      resource.data.userId == request.auth.uid ||
      resource.data.providerId == request.auth.uid ||
      ("providerIds" in resource.data && resource.data.providerIds.hasAny([request.auth.uid])) ||
      isAdmin()
    );

  allow create: if isSignedIn() &&
    request.resource.data.userId == request.auth.uid;

  allow update: if isAdmin();
  allow delete: if isAdmin();
}
    match /dms/{messageId} {
      allow read: if isDmParticipantExisting() || isAdmin();

      allow create: if isDmParticipantNew() &&
        request.resource.data.senderId == request.auth.uid;

      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    match /feedbacks/{feedbackId} {
  allow create: if isSignedIn()
    && request.resource.data.userId == request.auth.uid;

  allow read: if isAdmin()
    || resource.data.userId == request.auth.uid;

  allow update: if isAdmin();

  allow delete: if isAdmin();
}

    match /chats/{chatId} {
      allow read: if isChatParticipantExisting() || isAdmin();
      allow create: if isChatParticipantNew() || isAdmin();
      allow update: if isChatParticipantExisting() || isAdmin();
      allow delete: if isAdmin();
    }

    match /jobs/{jobId} {
      allow read: if isJobParticipant() || isAdmin();
      allow create: if isNewJobParticipant() || isAdmin();
      allow update: if isJobParticipant() || isAdmin();
      allow delete: if isAdmin();
    }

    match /shops/{shopId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /carts/{cartId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

 match /payments/{paymentId} {
  allow read: if isPaymentReader();

  allow create: if isPaymentCreator();

  allow update: if isSignedIn() &&
    (
      resource.data.userId == request.auth.uid ||
      resource.data.clientId == request.auth.uid ||
      resource.data.providerId == request.auth.uid ||
      (
        "providerIds" in resource.data &&
        resource.data.providerIds.hasAny([request.auth.uid])
      ) ||
      isAdmin()
    );

  allow delete: if isAdmin();
}
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );

      allow delete: if isSignedIn() &&
        (
          resource.data.userId == request.auth.uid ||
          isAdmin()
        );
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() &&
        (
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );

      allow create: if isSignedIn() &&
        request.resource.data.providerId == request.auth.uid;

      allow update: if isSignedIn() &&
        (
          resource.data.providerId == request.auth.uid ||
          isAdmin()
        );

      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin();

      allow create: if isSignedIn() &&
        request.resource.data.reportedBy == request.auth.uid;

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}